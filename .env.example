# Public FlowCast FastAPI base URL, including /api/v1.
NEXT_PUBLIC_API_URL=https://flowcast-backend-1.onrender.com/api/v1

# Public WebSocket base URL, including /api/v1.
NEXT_PUBLIC_WS_URL=wss://flowcast-backend-1.onrender.com/api/v1

# Server-only backend origin used by the optional /api/proxy rewrite.
BACKEND_URL=https://flowcast-backend-1.onrender.com
